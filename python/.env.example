# ─── Database ──────────────────────────────────────────────
# FastAPI domain tables (Alembic migrations)
DATABASE_URL=postgresql+asyncpg://creda_admin:creda_secure_2025@localhost:8010/creda_api
# Django tables — User, sessions, admin (Django migrations)
DJANGO_DATABASE_URL=postgresql://creda_admin:creda_secure_2025@localhost:8010/creda_django

# Django individual DB vars (used by settings.py — must use creda_django, not creda_api)
DJANGO_DB_NAME=creda_django
DJANGO_DB_PORT=8010
# If you see "relation auth_user does not exist" or "django_session does not exist", Django
# migrations were not applied: from python/ run  make migrate  (or  make migrate-django ).
# If migrate fails with password authentication failed for creda_admin, Postgres was
# likely initialized with an old password in a Docker volume. From python/: run
#   make postgres-volume-reset
# then make migrate (or make init again).


# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:8020/0

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-64-char-hex-string
DJANGO_SECRET_KEY=change-me-in-production-use-a-random-string

# ─── LLM ───────────────────────────────────────────────────
GROQ_API_KEY=

# ─── TTS / STT ────────────────────────────────────────────
KOKORO_TTS_URL=http://localhost:8880
PIPER_TTS_URL=http://localhost:8890
STT_ENGINE=faster-whisper

# ─── ChromaDB ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8030

# ─── Twilio (optional — for WhatsApp) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# POST /expenses from external tools (no x-user-id):
# Option A — shared secret (recommended): set WHATSAPP_EXPENSE_WEBHOOK_SECRET and send either
#   X-Webhook-Secret: <value>   or   Authorization: Bearer <value>
# Option B — dev/tunnels only: WHATSAPP_EXPENSE_TRUST_PUBLIC=true (no headers; anyone can post as user below)
# WHATSAPP_EXPENSE_WEBHOOK_SECRET=
# WHATSAPP_EXPENSE_USER_ID=100
# WHATSAPP_EXPENSE_TRUST_PUBLIC=false

# ─── Ports ─────────────────────────────────────────────────
DJANGO_PORT=8000
FASTAPI_PORT=8001

# ─── Ngrok / tunnel (remote users hitting Django on :8000) ─────────────────
# By default Django allows *.ngrok-free.app, *.ngrok.io, *.ngrok.app, *.loca.lt
# (see DJANGO_ALLOW_TUNNEL_HOSTS in settings). No need to list each random subdomain in ALLOWED_HOSTS.
#
# For HTTPS forms / login from the tunnel URL, set your exact public origin (ngrok URL changes each run):
#   TUNNEL_PUBLIC_URL=https://YOUR-SUBDOMAIN.ngrok-free.app
# Or use CSRF_TRUSTED_ORIGINS with the same URL(s), comma-separated.
#
# FastAPI browser calls: add the same https origin to backend CORS in python/.env:
#   CORS_ORIGINS=http://localhost:8000,https://YOUR-SUBDOMAIN.ngrok-free.app
#
# Disable wildcard tunnel hosts (local-only):
#   DJANGO_ALLOW_TUNNEL_HOSTS=false
#
# BACKEND_API_URL stays http://localhost:8001 when Django proxies server-side; only CORS needs the tunnel if the browser calls FastAPI directly.
