# ─── Database ──────────────────────────────────────────────
# FastAPI domain tables (Alembic migrations)
DATABASE_URL=postgresql+asyncpg://creda_admin:creda_secure_2025@localhost:8010/creda_api
# Django tables — User, sessions, admin (Django migrations)
DJANGO_DATABASE_URL=postgresql://creda_admin:creda_secure_2025@localhost:8010/creda_django

# Django individual DB vars (used by settings.py — must use creda_django, not creda_api)
DJANGO_DB_NAME=creda_django
DJANGO_DB_PORT=8010
# If you see "relation auth_user does not exist" or "django_session does not exist", Django
# migrations were not applied: from python/ run  make migrate  (or  make migrate-django ).
# If migrate fails with password authentication failed for creda_admin, Postgres was
# likely initialized with an old password in a Docker volume. From python/: run
#   make postgres-volume-reset
# then make migrate (or make init again).


# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:8020/0

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-64-char-hex-string
DJANGO_SECRET_KEY=change-me-in-production-use-a-random-string

# ─── LLM ───────────────────────────────────────────────────
GROQ_API_KEY=

# ─── TTS / STT ────────────────────────────────────────────
KOKORO_TTS_URL=http://localhost:8880
PIPER_TTS_URL=http://localhost:8890
STT_ENGINE=faster-whisper

# ─── ChromaDB ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8030

# ─── Twilio (optional — for WhatsApp) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ─── Ports ─────────────────────────────────────────────────
DJANGO_PORT=8000
FASTAPI_PORT=8001
